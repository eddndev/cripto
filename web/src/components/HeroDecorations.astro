<!-- Circuit Trace — top-right -->
<svg
  class="hero-deco hero-deco--circuit"
  viewBox="0 0 600 500"
  fill="none"
  stroke="currentColor"
  aria-hidden="true"
>
  <!-- Main traces -->
  <path class="hero-deco__path" d="M50 10 L50 80 L200 80 L200 150 L350 150" stroke-width="1.5" />
  <path class="hero-deco__path" d="M120 30 L120 120 L280 120 L280 200 L420 200" stroke-width="1.5" />
  <path class="hero-deco__path" d="M10 180 L90 180 L90 260 L240 260 L240 320 L380 320" stroke-width="1.5" />
  <path class="hero-deco__path" d="M180 50 L180 100 L310 100 L310 180 L450 180 L450 280" stroke-width="1.5" />
  <path class="hero-deco__path" d="M60 300 L150 300 L150 380 L300 380 L300 430 L500 430" stroke-width="1.5" />
  <!-- Branch traces -->
  <path class="hero-deco__path" d="M200 150 L200 220 L320 220" stroke-width="1" />
  <path class="hero-deco__path" d="M280 200 L280 270 L360 270" stroke-width="1" />
  <path class="hero-deco__path" d="M450 280 L520 280 L520 350" stroke-width="1" />
  <!-- Terminal nodes -->
  <circle class="hero-deco__node" cx="350" cy="150" r="4" fill="currentColor" stroke="none" />
  <circle class="hero-deco__node" cx="420" cy="200" r="4" fill="currentColor" stroke="none" />
  <circle class="hero-deco__node" cx="380" cy="320" r="4" fill="currentColor" stroke="none" />
  <circle class="hero-deco__node" cx="450" cy="280" r="3" fill="currentColor" stroke="none" />
  <circle class="hero-deco__node" cx="500" cy="430" r="4" fill="currentColor" stroke="none" />
  <circle class="hero-deco__node" cx="320" cy="220" r="3" fill="currentColor" stroke="none" />
  <circle class="hero-deco__node" cx="360" cy="270" r="3" fill="currentColor" stroke="none" />
  <circle class="hero-deco__node" cx="520" cy="350" r="3" fill="currentColor" stroke="none" />
</svg>

<!-- Hex Grid Fragment — left -->
<svg
  class="hero-deco hero-deco--hex"
  viewBox="0 0 500 450"
  fill="none"
  stroke="currentColor"
  aria-hidden="true"
>
  <!-- Row 1 -->
  <path class="hero-deco__path" d="M80 30 L110 15 L140 30 L140 60 L110 75 L80 60 Z" stroke-width="1.2" />
  <path class="hero-deco__path" d="M140 30 L170 15 L200 30 L200 60 L170 75 L140 60" stroke-width="1.2" />
  <path class="hero-deco__path" d="M200 30 L230 15 L260 30 L260 60" stroke-width="1.2" />
  <!-- Row 2 -->
  <path class="hero-deco__path" d="M110 75 L140 90 L140 120 L110 135 L80 120 L80 90 Z" stroke-width="1.2" />
  <path class="hero-deco__path" d="M170 75 L200 90 L200 120 L170 135 L140 120 L140 90" stroke-width="1.2" />
  <path class="hero-deco__path" d="M230 75 L260 90 L260 120 L230 135 L200 120 L200 90" stroke-width="1.2" />
  <path class="hero-deco__path" d="M290 75 L320 90 L320 120 L290 135" stroke-width="1.2" />
  <!-- Row 3 -->
  <path class="hero-deco__path" d="M80 150 L110 135 L140 150 L140 180 L110 195 L80 180 Z" stroke-width="1.2" />
  <path class="hero-deco__path" d="M140 150 L170 135 L200 150 L200 180 L170 195 L140 180" stroke-width="1.2" />
  <path class="hero-deco__path" d="M200 150 L230 135 L260 150 L260 180 L230 195" stroke-width="1.2" />
  <!-- Row 4 (partial) -->
  <path class="hero-deco__path" d="M110 195 L140 210 L140 240 L110 255 L80 240 L80 210" stroke-width="1.2" />
  <path class="hero-deco__path" d="M170 195 L200 210 L200 240" stroke-width="1.2" />
  <!-- Corner nodes -->
  <circle class="hero-deco__node" cx="110" cy="15" r="2.5" fill="currentColor" stroke="none" />
  <circle class="hero-deco__node" cx="170" cy="15" r="2.5" fill="currentColor" stroke="none" />
  <circle class="hero-deco__node" cx="110" cy="135" r="2.5" fill="currentColor" stroke="none" />
  <circle class="hero-deco__node" cx="230" cy="135" r="2.5" fill="currentColor" stroke="none" />
  <circle class="hero-deco__node" cx="110" cy="255" r="2.5" fill="currentColor" stroke="none" />
</svg>

<!-- Orbital Arcs — center-bottom -->
<svg
  class="hero-deco hero-deco--orbital"
  viewBox="0 0 400 400"
  fill="none"
  stroke="currentColor"
  aria-hidden="true"
>
  <!-- Concentric arcs -->
  <path class="hero-deco__path" d="M200 50 A150 150 0 0 1 350 200" stroke-width="1.2" />
  <path class="hero-deco__path" d="M350 200 A150 150 0 0 1 200 350" stroke-width="1.2" />
  <path class="hero-deco__path" d="M200 350 A150 150 0 0 1 50 200" stroke-width="1" />
  <path class="hero-deco__path" d="M200 90 A110 110 0 0 1 310 200" stroke-width="1.2" />
  <path class="hero-deco__path" d="M310 200 A110 110 0 0 1 200 310" stroke-width="1" />
  <path class="hero-deco__path" d="M200 130 A70 70 0 0 1 270 200" stroke-width="1.2" />
  <path class="hero-deco__path" d="M130 200 A70 70 0 0 1 200 130" stroke-width="1" />
  <!-- Radial lines -->
  <path class="hero-deco__path" d="M200 200 L200 50" stroke-width="0.8" />
  <path class="hero-deco__path" d="M200 200 L350 200" stroke-width="0.8" />
  <path class="hero-deco__path" d="M200 200 L306 94" stroke-width="0.8" />
  <!-- Data points -->
  <circle class="hero-deco__node" cx="200" cy="50" r="4" fill="currentColor" stroke="none" />
  <circle class="hero-deco__node" cx="350" cy="200" r="4" fill="currentColor" stroke="none" />
  <circle class="hero-deco__node" cx="200" cy="350" r="3" fill="currentColor" stroke="none" />
  <circle class="hero-deco__node" cx="50" cy="200" r="3" fill="currentColor" stroke="none" />
  <circle class="hero-deco__node" cx="310" cy="200" r="3" fill="currentColor" stroke="none" />
  <circle class="hero-deco__node" cx="270" cy="200" r="2.5" fill="currentColor" stroke="none" />
  <circle class="hero-deco__node" cx="200" cy="200" r="3" fill="currentColor" stroke="none" />
  <circle class="hero-deco__node" cx="306" cy="94" r="3" fill="currentColor" stroke="none" />
</svg>

<style>
  .hero-deco {
    position: absolute;
    color: var(--accent);
    pointer-events: none;
    z-index: 0;
  }

  .hero-deco--circuit {
    top: -5%;
    right: -8%;
    width: 50vw;
    max-width: 700px;
    opacity: 0.12;
  }

  .hero-deco--hex {
    left: -6%;
    top: 30%;
    width: 45vw;
    max-width: 600px;
    opacity: 0.10;
  }

  .hero-deco--orbital {
    bottom: -10%;
    left: 50%;
    transform: translateX(-50%);
    width: 35vw;
    max-width: 450px;
    opacity: 0.10;
  }

  .hero-deco__node {
    opacity: 0;
    transform-origin: center;
    transform: scale(0);
  }

  @media (max-width: 640px) {
    .hero-deco {
      display: none;
    }
  }
</style>
